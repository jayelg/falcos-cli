#!/usr/bin/bash
# Emit OSC 9;4 progress sequence for the goojust TUI.
# Usage: goojust-progress <pct> [label]
#        goojust-progress clear
#
# <pct>  0-100  percentage complete
# label  optional phase label shown above the bar (e.g. "Downloading...")
# clear  hides the progress bar
set -euo pipefail

if [[ "${1:-}" == "clear" ]]; then
	# State 0 = hide bar.
	printf '\e]9;4;0;0\e\\'
	exit 0
fi

pct="${1:-0}"
label="${2:-}"

# State 1 = show bar.
if [[ -n "$label" ]]; then
	printf '\e]9;4;1;%d;%s\e\\' "$pct" "$label"
else
	printf '\e]9;4;1;%d\e\\' "$pct"
fi
